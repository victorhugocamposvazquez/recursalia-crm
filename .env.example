NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini (imagen destacada por curso)
GOOGLE_GEMINI_API_KEY=
# Opcional: gemini-2.0-flash-preview-image-generation por defecto
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# WordPress (Application Password en Users → Perfil)
# IMPORTANTE: Usar comillas si el password tiene espacios
WORDPRESS_URL=https://tudominio.com
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# ID del usuario autor en WP (default 1 = admin). Requerido para Tutor Pro Topics/Lessons
# WORDPRESS_AUTHOR_ID=1

# WooCommerce (para precios en cursos Tutor LMS)
# Generar en: WooCommerce > Configuración > Avanzado > API REST
# WOOCOMMERCE_CONSUMER_KEY=ck_xxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxx

# Reseñas por curso (default 50)
# COURSE_REVIEWS_COUNT=50
